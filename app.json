{
  "expo": {
    "name": "Are You The One",
    "slug": "areyoutheone",
    "scheme": "areyoutheone",
    "version": "1.0.10",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#8B1538"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.areyoutheone.app",
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ]
      },
      "infoPlist": {
        "NSCameraUsageDescription": "We need camera access for profile photos and video intros.",
        "NSMicrophoneUsageDescription": "We need microphone access for voice and video calls.",
        "NSPhotoLibraryUsageDescription": "We need photo library access to upload profile pictures.",
        "NSLocationWhenInUseUsageDescription": "We need your location for safety check-ins during dates.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We need your location for safety check-ins during dates.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSExceptionDomains": {
            "jaspfotwnmjqqwoujnfm.supabase.co": {
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSExceptionMinimumTLSVersion": "TLSv1.2",
              "NSIncludesSubdomains": true
            }
          }
        }
      },
      "buildNumber": "28"
    },
    "android": {
      "gradleVersion": "8.6",
      "gradleProperties": {
        "android.useAndroidX": "true",
        "android.enableJetifier": "true"
      },
      "package": "com.areyoutheone.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#8B1538"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#8B1538",
          "image": "./assets/icon.png",
          "imageWidth": 280,
          "android": {
            "dark": {
              "backgroundColor": "#8B1538",
              "image": "./assets/icon.png"
            }
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "We need camera access for profile photos and video intros."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "We need your location for safety check-ins during dates."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#8B1538"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "We need photo library access to upload profile pictures."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "newArchEnabled": false
          },
          "android": {
            "newArchEnabled": false,
            "kotlinVersion": "1.9.25",
            "compileOptions": {
              "sourceCompatibility": "17",
              "targetCompatibility": "17"
            },
            "kotlinOptions": {
              "jvmTarget": "17"
            }
          }
        }
      ],
      "./plugins/withAndroidFixes"
    ],
    "extra": {
      "eas": {
        "projectId": "2da74c82-60d2-4ba1-b6d8-b4763c44f2a8"
      },
      "supabaseUrl": "https://jaspfotwnmjqqwoujnfm.supabase.co",
      "supabaseAnonKey": "sb_publishable_GH7GLZCvo9b99qrnsCNBUw_4S8gjI84"
    },
    "owner": "sulaaaas-organization"
  }
}
